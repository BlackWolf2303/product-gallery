{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "product-gallery-mcp",
  "main": "chatgpt-app/worker/index.mjs",
  "compatibility_date": "2026-05-22",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": true
  },
  "rules": [
    {
      "type": "Text",
      "globs": ["**/*.txt"],
      "fallthrough": true
    }
  ],
  "build": {
    "command": "npm run app:build"
  },
  "observability": {
    "enabled": true
  }
}
